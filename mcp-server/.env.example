# ── Calling the Organizer API ────────────────────────────────────────────────

# Base URL of the Organizer webapp API.
# Prefer the CloudFront URL (it injects x-origin-verify for you, so leave
# TODO_ORIGIN_SECRET blank). Use the Lambda Function URL only for direct testing,
# in which case TODO_ORIGIN_SECRET is required.
# (In the deployed Lambda this is set to the Organizer Function URL by SAM.)
TODO_API_URL=https://your-cloudfront-domain

# Cognito ACCESS token forwarded to the API as `Authorization: Bearer`.
# Auth is per-user pass-through:
#   - HTTP transport: the caller's token from the request is used (this is ignored).
#   - stdio transport: there is no incoming request, so THIS token is used.
# So you only need this for local stdio (Claude Code). Tokens expire ~1h.
TODO_API_KEY=your-cognito-access-token

# Outbound x-origin-verify, only when TODO_API_URL points directly at a Lambda
# Function URL (bypassing CloudFront). Must equal the /organizer/origin-secret
# SSM value. Leave blank when going through CloudFront.
TODO_ORIGIN_SECRET=

# ── Protecting the MCP endpoint (HTTP transport) ──────────────────────────────

# Incoming origin verification: if set, requests must carry a matching
# x-origin-verify header (CloudFront injects it). Blocks direct Function URL
# access. Leave blank for local HTTP testing. (Set by SAM in the deployed Lambda.)
ORIGIN_SECRET=

# If set, the MCP server validates the caller's Cognito ACCESS token before any
# tool/resource runs (and forwards it to the API). Leave blank to disable
# validation for local testing. (Set by SAM in the deployed Lambda.)
# AWS_REGION is provided automatically on Lambda; set it locally if you enable this.
COGNITO_USER_POOL_ID=

# ── Transport ─────────────────────────────────────────────────────────────────

# "stdio" for Claude Code, "http" for local Streamable HTTP testing.
# (On Lambda the server runs via src/handler.py, not MCP_TRANSPORT.)
MCP_TRANSPORT=stdio
HOST=127.0.0.1
PORT=3100
